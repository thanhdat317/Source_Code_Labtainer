# results.config
# 
# Please see the Labtainer Lab Designer User Guide
product_tampering = web-inject-server:journalctl.stdout : CONTAINS : Solved challenge Product Tampering
admin_registered  = web-inject-server:.local/result/admin_registered.txt : CONTAINS : @
login_jim         = web-inject-server:journalctl.stdout : CONTAINS : Solved challenge Login Jim
forged_feedback   = web-inject-server:journalctl.stdout : CONTAINS : Solved challenge Forged Feedback
payback_time      = web-inject-server:journalctl.stdout : CONTAINS : Solved challenge Payback Time
nosql_injection   = web-inject-server:journalctl.stdout : CONTAINS : Solved challenge NoSQL Injection Tier 2
user_credentials  = web-inject-server:journalctl.stdout : CONTAINS : Solved challenge User Credentials
sqli_file         = web-inject:Desktop/sqli.txt : CONTAINS : UNION SELECT
zap_report        = web-inject:.local/result/report_status.txt : CONTAINS : ZAP_REPORT_OK
