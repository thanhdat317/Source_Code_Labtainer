# results.config
# 
# Please see the Labtainer Lab Designer User Guide
xxe_etc_passwd_evil1 = web-xxe-server:.local/result/xxe_results.txt : CONTAINS : [LAB-XXE] payload=evil1.xml target=/etc/passwd
xxe_etc_passwd_evil2 = web-xxe-server:.local/result/xxe_results.txt : CONTAINS : [LAB-XXE] payload=evil2.xml target=/etc/passwd
xxe_flag_evil3       = web-xxe-server:.local/result/xxe_results.txt : CONTAINS : [LAB-XXE] payload=evil3.xml target=/opt/secret/flag.txt
zap_report           = web-xxe:.local/result/report_status.txt : CONTAINS : report_zap=present
