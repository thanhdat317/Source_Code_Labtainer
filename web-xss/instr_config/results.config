# results.config
# 
# Please see the Labtainer Lab Designer User Guide
rxss_p1 = web-xss:.local/result/moz_places.txt : CONTAINS : search?q=%3Cscript%3Ealert(1)%3B%3C%2Fscript%3E
rxss_p2 = web-xss:.local/result/moz_places.txt : CONTAINS : search?q=%3CIMG%20%22%22%3E%3CSCRIPT%3Ealert(%22XSS%22)%3C%2FSCRIPT%3E%22%5C%3E
rxss_p3 = web-xss:.local/result/moz_places.txt : CONTAINS : search?q=%3CIMG%20SRC%3D%2F%20onerror%3D%22alert(String.fromCharCode(88%2C83%2C83))%22%3E%3C%2Fimg%3E
sxss_reg = web-xss-server:.local/result/registered_users.txt : CONTAINS : <script>alert("XSS")</script>
sxss_adm = web-xss:.local/result/moz_places.txt : CONTAINS : administration
comp_pdf = web-xss-server:.local/result/complaints_list.txt : CONTAINS : testfile.pdf
comp_xml = web-xss-server:.local/result/journalctl.stdout : CONTAINS : testfile.xml
apix_p2 = web-xss-server:.local/result/product2_desc.txt : CONTAINS : <iframe src="javascript:alert(`xss`)">
apix_p6 = web-xss-server:.local/result/product6_price.txt : CONTAINS : <script>alert(1);</script>
zap_rep = web-xss:.local/result/zap_report.txt : CONTAINS : zap_report_created
