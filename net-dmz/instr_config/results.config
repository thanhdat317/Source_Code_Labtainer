# results.config
#
# Checkwork artifacts are collected by prestop after the student has tested
# the firewall policy.  CHECK_TRUE rules must be present; CHECK_FALSE rules
# must be absent.
#
#CHECK_TRUE: Remote workstation can reach SSH on the DMZ web server.
cw_remote_ssh = remote_ws:prestop.stdout : FILE_REGEX : open[ ]+ssh
#CHECK_TRUE: Remote workstation can reach HTTP on the DMZ web server.
cw_remote_http = remote_ws:prestop.stdout : FILE_REGEX : open[ ]+http
#CHECK_TRUE: Remote workstation can reach HTTPS on the DMZ web server.
cw_remote_https = remote_ws:prestop.stdout : FILE_REGEX : open[ ]+https
#CHECK_FALSE: Remote workstation must not reach MySQL.
cw_remote_mysql = remote_ws:prestop.stdout : FILE_REGEX : open[ ]+mysql
#CHECK_FALSE: Remote workstation must not reach an internal workstation web service.
cw_remote_ws2 = remote_ws:prestop.stdout : FILE_REGEX : 198.18.1.194.*saved
#CHECK_TRUE: Internal users can reach SSH, HTTP, HTTPS, and MySQL on the DMZ web server.
cw_local_ssh = ws1:prestop.stdout : FILE_REGEX : open[ ]+ssh
cw_local_http = ws1:prestop.stdout : FILE_REGEX : open[ ]+http
cw_local_https = ws1:prestop.stdout : FILE_REGEX : open[ ]+https
cw_local_mysql = ws1:prestop.stdout : FILE_REGEX : open[ ]+mysql
#CHECK_TRUE: Internal users can reach the Internet.
cw_reach_internet = ws1:prestop.stdout : FILE_REGEX : index.html.*saved
