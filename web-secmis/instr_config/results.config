# Please see the Labtainer Lab Designer User Guide
password     = web-secmis-server:journalctl.stdout : CONTAINS : Password
login_admin  = web-secmis-server:journalctl.stdout : CONTAINS : Login Admin
login_jim    = web-secmis-server:journalctl.stdout : CONTAINS : Login Jim
score_board          = web-secmis-server:journalctl.stdout : CONTAINS : Score Board
error_handling       = web-secmis-server:journalctl.stdout : CONTAINS : Error Handling
deprecated_interface = web-secmis-server:journalctl.stdout : CONTAINS : Deprecated Interface
premium_paywall      = web-secmis-server:journalctl.stdout : CONTAINS : Premium Paywall
admin_section        = web-secmis-server:journalctl.stdout : CONTAINS : Admin Section
forged_feedback      = web-secmis-server:journalctl.stdout : CONTAINS : Forged Feedback
zap_report_spider    = web-secmis:.local/result/zap_report_spider.txt : CONTAINS : zap_report_spider_created
zap_report_final     = web-secmis:.local/result/zap_report_final.txt : CONTAINS : zap_report_final_created
